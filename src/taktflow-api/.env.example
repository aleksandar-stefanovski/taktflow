# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/taktflow
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# ── Auth secrets (min 32 chars) ────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
API_KEY_SIGNING_SECRET=

# ── Token expiry ───────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=30

# ── Argon2 password hashing ────────────────────────────────────────────────────
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ── API key ────────────────────────────────────────────────────────────────────
API_KEY_PREFIX=sk_live_

# ── HTTP security ──────────────────────────────────────────────────────────────
MAX_PAYLOAD_SIZE_BYTES=262144
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=1 minute

# ── Pagination ─────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=100
MAX_PAGE_SIZE=500

# ── Plan event limits (events per month) ───────────────────────────────────────
PLAN_STARTER_EVENTS_PER_MONTH=100000
PLAN_GROWTH_EVENTS_PER_MONTH=1000000
PLAN_BUSINESS_EVENTS_PER_MONTH=10000000
PLAN_ENTERPRISE_EVENTS_PER_MONTH=100000000

# ── Retry backoff (base delay; each attempt doubles: base, base*2, base*4 …) ───
RETRY_BASE_DELAY_MS=30000

# ── Retry policy ──────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
ALERT_AFTER_FAILURES=3

# ── Topic defaults ─────────────────────────────────────────────────────────────
TOPIC_DEFAULT_RETENTION_DAYS=7
TOPIC_DEFAULT_MAX_PAYLOAD_KB=256
TOPIC_DEFAULT_ORDERING=unordered

# ── External services ──────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:3001
RESEND_API_KEY=

# ── Optional integrations ──────────────────────────────────────────────────────
CLERK_SECRET_KEY=
