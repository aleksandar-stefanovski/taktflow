{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@domain/*":         ["../taktflow-domain/*"],
      "@persistence/*":    ["./*"],
      "@utils/*":          ["../taktflow-utils/*"]
    }
  },
  "references": [
    { "path": "../taktflow-domain" },
    { "path": "../taktflow-utils" }
  ],
  "include": ["schema", "database.ts", "repositories", "interfaces", "queue", "query.helper.ts"],
  "exclude": ["node_modules", "dist"]
}
