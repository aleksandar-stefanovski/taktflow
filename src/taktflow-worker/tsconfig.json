{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@domain/*":         ["../taktflow-domain/*"],
      "@persistence/*":    ["../taktflow-persistence/*"],
      "@infrastructure/*": ["../taktflow-infrastructure/*"],
      "@application/*":    ["../taktflow-application/*"],
      "@worker/*":         ["./*"],
      "@utils/*":          ["../taktflow-utils/*"]
    }
  },
  "references": [
    { "path": "../taktflow-domain" },
    { "path": "../taktflow-persistence" },
    { "path": "../taktflow-infrastructure" },
    { "path": "../taktflow-application" },
    { "path": "../taktflow-utils" }
  ],
  "include": ["services", "interfaces", "models", "helpers", "extensions", "config", "worker.ts", "worker-factory.ts"],
  "exclude": ["node_modules", "dist"]
}
