# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/taktflow

# ── Runtime ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Email alerts ───────────────────────────────────────────────────────────────
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@taktflow.io

# ── Worker core ────────────────────────────────────────────────────────────────
WORKER_BATCH_SIZE=50
WORKER_POLL_INTERVAL_MS=100
WORKER_DELIVERY_TIMEOUT_MS=30000
WORKER_STUCK_THRESHOLD_MS=60000
WORKER_UNSTUCK_INTERVAL_MS=30000
WORKER_RETRY_INTERVAL_MS=5000
WORKER_SCHEDULER_INTERVAL_MS=10000
WORKER_ALERT_INTERVAL_MS=60000
WORKER_CLEANUP_INTERVAL_MS=86400000
WORKER_METRICS_FLUSH_INTERVAL_MS=60000
WORKER_SHUTDOWN_POLL_INTERVAL_MS=100
WORKER_SHUTDOWN_MAX_WAIT_MS=30000

# ── Worker limits ──────────────────────────────────────────────────────────────
WORKER_DEFAULT_RETRY_ATTEMPTS=3
WORKER_SCHEDULER_BATCH_SIZE=50
WORKER_SCHEDULER_CONSUMER_LIMIT=100
WORKER_AWAITING_ACK_TIMEOUT_HOURS=1
WORKER_MEMORY_WARNING_THRESHOLD_MB=400
WORKER_MAX_RETENTION_DAYS=90
WORKER_MAX_RESPONSE_BODY_BYTES=1024

# ── Retry backoff (base delay; each attempt doubles: base, base*2, base*4 …) ───
RETRY_BASE_DELAY_MS=30000
