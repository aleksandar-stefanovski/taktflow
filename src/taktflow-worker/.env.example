DATABASE_URL=postgresql://user:password@localhost:5432/taktflow
LOG_LEVEL=info
WORKER_BATCH_SIZE=50
WORKER_POLL_INTERVAL_MS=100
WORKER_DELIVERY_TIMEOUT_MS=30000
WORKER_STUCK_THRESHOLD_SECONDS=60
WORKER_UNSTUCK_INTERVAL_MS=30000
WORKER_RETRY_INTERVAL_MS=5000
WORKER_SCHEDULER_INTERVAL_MS=10000
WORKER_ALERT_INTERVAL_MS=60000
WORKER_CLEANUP_INTERVAL_MS=86400000
WORKER_METRICS_FLUSH_INTERVAL_MS=60000
WORKER_SHUTDOWN_POLL_INTERVAL_MS=100
