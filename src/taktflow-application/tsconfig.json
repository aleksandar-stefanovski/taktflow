{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@domain/*":         ["../taktflow-domain/*"],
      "@application/*":    ["./*"],
      "@utils/*":          ["../taktflow-utils/*"]
    }
  },
  "references": [
    { "path": "../taktflow-domain" },
    { "path": "../taktflow-utils" }
  ],
  "include": ["interfaces", "contracts", "requests", "responses", "services", "validators"],
  "exclude": ["node_modules", "dist"]
}
