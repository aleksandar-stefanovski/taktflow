{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@domain/*":         ["../taktflow-domain/*"],
      "@application/*":    ["./*"]
    }
  },
  "references": [
    { "path": "../taktflow-domain" }
  ],
  "include": ["interfaces", "requests", "responses", "services", "validators", "helpers"],
  "exclude": ["node_modules", "dist"]
}
