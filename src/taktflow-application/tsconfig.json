{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@domain/*":         ["../taktflow-domain/*"],
      "@types/*":          ["../../packages/taktflow-types/*"],
      "@utils/*":          ["../../packages/taktflow-utils/*"],
      "@application/*":    ["./*"]
    }
  },
  "references": [
    { "path": "../taktflow-domain" },
    { "path": "../../packages/taktflow-types" }
  ],
  "include": ["commands", "queries", "handlers", "requests", "responses", "validators", "mappers", "interfaces"],
  "exclude": ["node_modules", "dist"]
}
