{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@domain/*":         ["../taktflow-domain/*"],
      "@persistence/*":    ["../taktflow-persistence/*"],
      "@infrastructure/*": ["./*"]
    }
  },
  "references": [
    { "path": "../taktflow-domain" },
    { "path": "../taktflow-persistence" }
  ],
  "include": ["auth", "context", "email", "interfaces", "persistence", "queue", "constants"],
  "exclude": ["node_modules", "dist"]
}
