{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@domain/*":         ["../taktflow-domain/*"],
      "@persistence/*":    ["../taktflow-persistence/*"],
      "@types/*":          ["../../packages/taktflow-types/*"],
      "@utils/*":          ["../../packages/taktflow-utils/*"],
      "@infrastructure/*": ["./*"]
    }
  },
  "references": [
    { "path": "../taktflow-domain" },
    { "path": "../taktflow-persistence" },
    { "path": "../../packages/taktflow-types" }
  ],
  "include": ["persistence", "queue", "interfaces", "email"],
  "exclude": ["node_modules", "dist"]
}
